# MongoDB Connection String (get from mongodb.com — free cluster)
MONGODB_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/umapati-vatralay?retryWrites=true&w=majority

# Google Gemini API Key (get from https://aistudio.google.com/api-keys)
# Required for Vercel deployment. Local dev falls back to z-ai-web-dev-sdk.
GEMINI_API_KEY=your_gemini_api_key_here